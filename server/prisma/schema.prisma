generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Rol {
  id_rol                Int          @id @default(autoincrement())
  nombre                String       @db.VarChar(50)
  descripcion           String?      @db.VarChar(150)
  estado                Int          @default(1) @db.TinyInt
  fecha_creacion        DateTime     @default(now())
  fecha_actualizacion   DateTime?
  usuario_creacion      Int?
  usuario_actualizacion Int?
  usuarios              Usuario[]
  rol_permisos          RolPermiso[]

  @@map("roles")
}

model Permiso {
  id_permiso            Int          @id @default(autoincrement())
  nombre                String       @db.VarChar(80)
  descripcion           String?      @db.VarChar(150)
  estado                Int          @default(1) @db.TinyInt
  fecha_creacion        DateTime     @default(now())
  fecha_actualizacion   DateTime?
  usuario_creacion      Int?
  usuario_actualizacion Int?
  rol_permisos          RolPermiso[]

  @@map("permisos")
}

model RolPermiso {
  id         Int     @id @default(autoincrement())
  id_rol     Int
  id_permiso Int
  estado     Int     @default(1) @db.TinyInt
  rol        Rol     @relation(fields: [id_rol], references: [id_rol])
  permiso    Permiso @relation(fields: [id_permiso], references: [id_permiso])

  @@map("rol_permiso")
}

model Usuario {
  id_usuario            Int                   @id @default(autoincrement())
  nombre                String                @db.VarChar(100)
  correo                String                @unique @db.VarChar(120)
  clave                 String                @db.VarChar(255)
  id_rol                Int?
  telefono              String?               @db.VarChar(20)
  estado                Int                   @default(1) @db.TinyInt
  fecha_creacion        DateTime              @default(now())
  fecha_actualizacion   DateTime?
  usuario_creacion      Int?
  usuario_actualizacion Int?
  rol                   Rol?                  @relation(fields: [id_rol], references: [id_rol])
  codigos_verificacion  CodigoVerificacion[]

  @@map("usuarios")
}

model CodigoVerificacion {
  id             Int      @id @default(autoincrement())
  id_usuario     Int
  codigo         String   @db.VarChar(6)
  expira_en      DateTime
  usado          Int      @default(0) @db.TinyInt
  fecha_creacion DateTime @default(now())
  usuario        Usuario  @relation(fields: [id_usuario], references: [id_usuario])

  @@map("codigos_verificacion")
}

model Bobina {
  id_bobina               Int       @id @default(autoincrement())
  id_lote                 Int
  lote_rel                Lote      @relation(fields: [id_lote], references: [id_lote])
  color                   String?   @db.VarChar(50)
  espesor                 Decimal?  @db.Decimal(5, 2)
  ancho                   Decimal?  @db.Decimal(8, 2)
  peso_inicial            Decimal?  @db.Decimal(10, 2)
  peso_actual             Decimal?  @db.Decimal(10, 2)
  metros_lineales_inicial Decimal?  @db.Decimal(10, 2)
  metros_lineales_actual  Decimal?  @db.Decimal(10, 2)
  estado_bobina           String?   @db.VarChar(50)
  estado                  Int       @default(1) @db.TinyInt
  fecha_creacion          DateTime  @default(now())
  fecha_actualizacion   DateTime?
  usuario_creacion      Int?
  usuario_actualizacion Int?

  @@map("bobinas")
}

model Lote {
  id_lote               Int       @id @default(autoincrement())
  codigo_lote           String    @unique @db.VarChar(50)
  id_proveedor          Int?
  proveedor_rel         Proveedor? @relation(fields: [id_proveedor], references: [id_proveedor])
  fecha_ingreso         DateTime? @db.Date
  estado                Int       @default(1) @db.TinyInt
  fecha_creacion        DateTime  @default(now())
  fecha_actualizacion   DateTime?
  usuario_creacion      Int?
  usuario_actualizacion Int?
  bobinas               Bobina[]

  @@map("lotes")
}

model Proveedor {
  id_proveedor          Int       @id @default(autoincrement())
  nombre                String    @db.VarChar(100)
  contacto              String?   @db.VarChar(100)
  telefono              String?   @db.VarChar(20)
  correo                String?   @db.VarChar(120)
  direccion             String?   @db.Text
  estado                Int       @default(1) @db.TinyInt
  fecha_creacion        DateTime  @default(now())
  fecha_actualizacion   DateTime?
  usuario_creacion      Int?
  usuario_actualizacion Int?
  lotes                 Lote[]

  @@map("proveedores")
}

model TipoProducto {
  id_tipo_producto      Int       @id @default(autoincrement())
  nombre                String    @db.VarChar(100)
  estado                Int       @default(1) @db.TinyInt
  fecha_creacion        DateTime  @default(now())
  fecha_actualizacion   DateTime?
  usuario_creacion      Int?
  usuario_actualizacion Int?
  productos             Producto[]

  @@map("tipos_productos")
}

model Producto {
  id_producto           Int               @id @default(autoincrement())
  id_tipo_producto      Int?
  descripcion           String?           @db.Text
  medida_largo          Decimal?          @db.Decimal(10, 2)
  medida_ancho          Decimal?          @db.Decimal(10, 2)
  estado                Int               @default(1) @db.TinyInt
  fecha_creacion        DateTime          @default(now())
  fecha_actualizacion   DateTime?
  usuario_creacion      Int?
  usuario_actualizacion Int?
  
  tipo_producto         TipoProducto?     @relation(fields: [id_tipo_producto], references: [id_tipo_producto])
  dibujos               DibujoCalamina[]
  pedido_detalles       PedidoDetalle[]

  @@map("productos")
}

model DibujoCalamina {
  id_dibujo             Int       @id @default(autoincrement())
  id_producto           Int
  largo                 Decimal   @db.Decimal(10, 2)
  ancho                 Decimal   @db.Decimal(10, 2)
  area_plana            Decimal?  @db.Decimal(12, 2)
  area_proyectada       Decimal?  @db.Decimal(12, 2)
  configuracion_calculo Json?     // Almacena pendientes, cumbres, limas, etc.
  datos_json            String?   @db.Text
  imagen_generada       String?   @db.Text
  estado                Int       @default(1) @db.TinyInt
  fecha_creacion        DateTime  @default(now())
  fecha_actualizacion   DateTime?
  usuario_creacion      Int?
  usuario_actualizacion Int?
  producto              Producto  @relation(fields: [id_producto], references: [id_producto])
  pedidos               Pedido[]

  @@map("productos_dibujos")
}

model Pedido {
  id_pedido             Int             @id @default(autoincrement())
  nombre_cliente        String          @db.VarChar(150)
  fecha                 DateTime        @db.Date
  id_dibujo             Int?
  dibujo                DibujoCalamina? @relation(fields: [id_dibujo], references: [id_dibujo])
  subtotal              Decimal?        @db.Decimal(12, 2)
  total                 Decimal?        @db.Decimal(12, 2)
  observaciones         String?         @db.Text
  estado_pedido         String          @default("pendiente") @db.VarChar(30)
  estado                Int             @default(1) @db.TinyInt
  fecha_creacion        DateTime        @default(now())
  fecha_actualizacion   DateTime?
  usuario_creacion      Int?
  usuario_actualizacion Int?
  detalles              PedidoDetalle[]

  @@map("pedidos")
}

model PedidoDetalle {
  id_detalle            Int       @id @default(autoincrement())
  id_pedido             Int
  pedido                Pedido    @relation(fields: [id_pedido], references: [id_pedido])
  id_producto           Int
  producto              Producto  @relation(fields: [id_producto], references: [id_producto])
  cantidad              Int
  precio_unitario       Decimal   @db.Decimal(10, 2)
  subtotal              Decimal?  @db.Decimal(12, 2)
  estado                Int       @default(1) @db.TinyInt

  @@map("pedido_detalles")
}